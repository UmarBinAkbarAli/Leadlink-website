---
interface Props {
  title: string;
  headHtml?: string;
}

const { title, headHtml = '' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <Fragment set:html={headHtml} />
  </head>
  <body>
    <slot />
  </body>
</html>
